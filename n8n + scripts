function leerLista(rutaArchivo) {
    try {
        return JSON.parse(fs.readFileSync(rutaArchivo, 'utf8'));
    } catch (e) {
        console.error(`Error leyendo ${rutaArchivo}:`, e.message);
        return [];
    }
}

function guardarLista(rutaArchivo, lista) {
    try {
        fs.writeFileSync(rutaArchivo, JSON.stringify(lista, null, 2), 'utf8');
    } catch (e) {
        console.error(`Error guardando ${rutaArchivo}:`, e.message);
    }
