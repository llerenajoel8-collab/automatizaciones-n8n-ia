            await page.wait_for_selector('input[name="q"], input#searchboxinput', timeout=15000)
        except:
            print("No se encontró el buscador, intentando igual...")

        search_box = await page.query_selector('input[name="q"]')
        if not search_box:
            search_box = await page.query_selector('input#searchboxinput')
        if not search_box:
            search_box = await page.query_selector('input[type="text"]')

        if not search_box:
            print("ERROR: No se pudo encontrar el buscador de Maps.")
            await browser.close()
            return

        await search_box.click()
        await page.wait_for_timeout(1000)
        await search_box.fill(BUSQUEDA)
        await page.wait_for_timeout(1000)
        await page.keyboard.press("Enter")
        await page.wait_for_timeout(4000)

        print("Haciendo scroll para cargar más resultados...")
        for _ in range(12):
            try:
                panel = await page.query_selector('div[role="feed"]')
                if panel:
                    await panel.evaluate("el => el.scrollBy(0, 800)")
                else:
                    await page.evaluate("window.scrollBy(0, 800)")
            except:
                pass
            await page.wait_for_timeout(1500)

        print("Extrayendo negocios...")
        resultados = await page.query_selector_all('a[href*="/maps/place/"]')
