                mensaje: textoFinal,
                contieneImagen: true,
                esComprobante: esComprobanteProbable
            });
        }
        // 💬 GESTIÓN DE TEXTO NORMAL
        else if (msg.body) {
            await delayHumanizado();
            await axios.post(N8N_WEBHOOK_URL, {
                remitente: msg.from,
                mensaje: msg.body,
                contieneImagen: false,
                esComprobante: false
            });
        }
    } catch (err) {
