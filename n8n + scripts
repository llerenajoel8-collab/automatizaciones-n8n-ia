        }
        try:
            r = requests.get(PROVEEDORES_URL, headers=HEADERS, params=params, timeout=15)
            if r.status_code == 200:
                for p in r.json().get("objects", []):
                    if p["id"] not in todos:
                        todos[p["id"]] = p
        except Exception as e:
            print(f"  Error cat {cat_id}: {e}")
        time.sleep(0.4)
    return list(todos.values())

def obtener_metricas(supplier_id):
    try:
        r = requests.get(
            METRICAS_URL.format(id=supplier_id),
            headers=HEADERS,
            timeout=10
        )
        if r.status_code == 200:
            data = r.json().get("data", {})
            return {
                "ordenes_mes": data.get("total_monthly_orders", ""),
                "productos_mes": data.get("total_monthly_products", ""),
                "dropshippers": data.get("total_monthly_dropshippers", ""),
            }
    except:
        pass
    return {"ordenes_mes": "", "productos_mes": "", "dropshippers": ""}

def obtener_productos(supplier_id, supplier_name, page_size=100):
    productos = []
    start = 0
    while True:
        body = {
            "pageSize": page_size,
            "startData": start,
            "supplier_id": supplier_id,
            "privated_product": False,
            "userVerified": False,
            "country": "ECUADOR",
            "favorite": False,
            "get_stock": False,
            "no_count": True,
            "search_type": "simple",
            "with_collection": True,
        }
        try:
            r = requests.post(PRODUCTOS_URL, headers=HEADERS, json=body, timeout=15)
            if r.status_code == 200:
                items = r.json().get("objects", [])
                if not items:
                    break
                productos.extend(items)
                if len(items) < page_size:
                    break
                start += page_size
                time.sleep(0.5)
            else:
                break
        except Exception as e:
            print(f"    Error productos: {e}")
            break
    return productos

def calcular_margen(sale_price, suggested_price):
    try:
        s = float(sale_price)
        p = float(suggested_price)
        if s > 0 and p > 0:
            ganancia = p - s
            margen = (ganancia / p) * 100
            return round(ganancia, 2), round(margen, 1)
    except:
        pass
    return 0, 0

