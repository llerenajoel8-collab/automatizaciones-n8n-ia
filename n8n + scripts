                }

                leads.append(lead)
                print(f"    Tel: {telefono} | Cal: {calificacion} | Reseñas: {resenas} | Web: {'Sí' if sitio_web else 'NO'} | {oportunidad}")

                await detalle.close()
                await page.wait_for_timeout(500)

            except Exception as e:
                print(f"  Error: {e}")
                continue

        await browser.close()

        if leads:
            with open(ARCHIVO_SALIDA, "w", newline="", encoding="utf-8-sig") as f:
                campos = ["nombre", "telefono", "calificacion", "resenas", "sitio_web", "direccion", "oportunidad", "url_maps"]
                writer = csv.DictWriter(f, fieldnames=campos)
                writer.writeheader()
                writer.writerows(leads)
            print(f"\n✓ Listo. {len(leads)} leads guardados en '{ARCHIVO_SALIDA}'")
            print(f"  Abre el archivo con Excel desde tu escritorio.")
        else:
            print("\nNo se encontraron resultados. Intenta de nuevo.")

asyncio.run(scrape_maps())
