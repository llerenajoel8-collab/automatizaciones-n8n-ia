        "jsCode": "const data = $input.first().json.result;\n\nif (!data) {\n  return [];\n}\n\nlet score = 0;\nconst razones = [];\nconst oportunidades = [];\n\n// CRITERIO 1: Sin sitio web (+40 puntos) — el más importante\nif (!data.website) {\n  score += 40;\n  razones.push('Sin sitio web');\n  oportunidades.push('Crear sitio web profesional');\n} else {\n  oportunidades.push('Rediseño o mejora de web existente');\n}\n\n// CRITERIO 2: Pocas reseñas (+30 puntos)\nconst totalReseñas = data.user_ratings_total || 0;\nif (totalReseñas < 10) {\n  score += 30;\n  razones.push('Menos de 10 reseñas');\n  oportunidades.push('Estrategia de reputación online');\n} else if (totalReseñas < 30) {\n  score += 15;\n  razones.push('Pocas reseñas (menos de 30)');\n  oportunidades.push('Aumentar visibilidad en Google');\n}\n\n// CRITERIO 3: Rating bajo o sin rating (+20 puntos)\nconst rating = data.rating || 0;\nif (rating === 0) {\n  score += 20;\n  razones.push('Sin puntuación en Google');\n  oportunidades.push('Activar perfil de Google Business');\n} else if (rating < 3.5) {\n  score += 20;\n  razones.push('Rating bajo (menos de 3.5)');\n  oportunidades.push('Gestión de reseñas negativas');\n} else if (rating < 4.2) {\n  score += 10;\n  razones.push('Rating mejorable');\n}\n\n// CRITERIO 4: Negocio activo pero poca presencia (+10 puntos)\nif (data.business_status === 'OPERATIONAL') {\n  score += 10;\n  oportunidades.push('Negocio activo — cliente potencial real');\n}\n\n// Nivel de oportunidad\nlet nivel = '';\nlet emoji = '';\nif (score >= 70) {\n  nivel = 'ALTA';\n  emoji = '🔴';\n} else if (score >= 40) {\n  nivel = 'MEDIA';\n  emoji = '🟡';\n} else {\n  nivel = 'BAJA';\n  emoji = '⚪';\n}\n\n// Mensaje de apertura sugerido\nlet mensajeApertura = '';\nif (!data.website) {\n  mensajeApertura = `Hola, vi su negocio \"${data.name}\" en Google Maps y noté que no tienen sitio web. Muchos de sus competidores sí tienen y están captando clientes online. ¿Tienen 10 minutos para que les muestre lo que están perdiendo?`;\n} else {\n  mensajeApertura = `Hola, analicé la presencia digital de \"${data.name}\" y encontré algunas oportunidades de mejora importantes. ¿Puedo mostrarles un diagnóstico gratuito?`;\n}\n\nreturn [{\n  json: {\n    // Datos del negocio\n    nombre: data.name || 'Sin nombre',\n    direccion: data.formatted_address || 'Sin dirección',\n    telefono: data.formatted_phone_number || '❌ No disponible',\n    web: data.website || '❌ Sin sitio web',\n    \n    // Métricas de Google\n    rating: rating || '⚠️ Sin rating',\n    total_reseñas: totalReseñas,\n    estado: data.business_status === 'OPERATIONAL' ? '✅ Activo' : '⚠️ ' + (data.business_status || 'Desconocido'),\n    \n    // Scoring de oportunidad\n    score_oportunidad: score,\n    nivel_oportunidad: `${emoji} ${nivel}`,\n    razones_score: razones.join(' | '),\n    servicios_a_ofrecer: oportunidades.join(' | '),\n    \n    // Herramienta de ventas\n    mensaje_apertura: mensajeApertura,\n    \n    // Metadata\n    lugar_id: data.place_id || '',\n    fecha_analisis: new Date().toLocaleDateString('es-EC')\n  }\n}];\n"
