        "jsCode": "const remitente = $('Clasificar mensaje').item.json.remitente;\nconst mensajeOriginal = $('Webhook WhatsApp').item.json.body.mensaje || \"\";\nconst fecha = new Date().toLocaleDateString('es-EC', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' });\n\n// 🕵️‍♂️ Intento de extracción rápida de nombres si la mamá los escribió junto al comprobante\nlet nombreNino = 'Por verificar en chat';\nlet nombreRepresentante = 'Por verificar en chat';\n\n// Si el mensaje tiene texto largo, intentamos buscar palabras clave\nconst texto = mensajeOriginal.toLowerCase();\nif (texto.includes('de ') || texto.includes('para ')) {\n  // Un intento básico de rescate de info para no dejarlo vacío si viene texto adjunto\n  nombreNino = mensajeOriginal; \n}\n\nconst contenido = `===== COMPROBANTE RECIBIDO (PRE-VALIDADO) =====\\nFecha: ${fecha}\\nWhatsApp remitente: ${remitente}\\nTexto adjunto: ${mensajeOriginal}\\n==============================================\\n\\n`;\n\nreturn [{ \n  json: { \n    contenido, \n    nombreArchivo: `comprobante_${Date.now()}.txt`, \n    datosInscrito: { \n      nombreNino: nombreNino, \n      nombreRepresentante: nombreRepresentante, \n      edad: 'Por verificar', \n      telefono: remitente \n    } \n  } \n}];"
